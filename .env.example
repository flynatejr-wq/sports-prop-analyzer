# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Sports Prop Analyzer
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sportsprops
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sportsprops
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/sportsprops

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── External APIs ─────────────────────────────────────────────────────────────
# TheOddsAPI: https://the-odds-api.com — free tier: 500 req/month
THE_ODDS_API_KEY=your_odds_api_key_here

# BallDontLie: https://balldontlie.io — free tier available
BALLDONTLIE_API_KEY=your_balldontlie_key_here

# ── Alert Channels ────────────────────────────────────────────────────────────
# Discord: create a webhook in Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Telegram: create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Twilio SMS: https://twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
ALERT_PHONE_NUMBERS=+1XXXXXXXXXX,+1YYYYYYYYYY

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=email1@example.com,email2@example.com

# ── Analysis Settings ─────────────────────────────────────────────────────────
EV_ALERT_THRESHOLD=5.0
MIN_CONFIDENCE=55.0
STALE_LINE_MINUTES=30
REFRESH_INTERVAL=30

# ── Scraping ──────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=15
MAX_RETRIES=3
RETRY_DELAY=1.5
USE_PROXIES=false
# PROXY_LIST=http://proxy1:port,http://proxy2:port

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
